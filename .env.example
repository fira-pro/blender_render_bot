# ── Telegram Credentials ─────────────────────────────────────────────────────
# Obtain from https://my.telegram.org → API development tools
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456789:AABBccDDeeFFggHHiiJJkkLL

# Comma-separated Telegram user IDs allowed to use the bot
WHITELIST_USER_IDS=123456789

# ── Blender ───────────────────────────────────────────────────────────────────
# Full path to the Blender 5.1 executable
# Linux example:  /usr/local/blender/blender
# Colab example:  /content/blender/blender
BLENDER_PATH=/usr/local/blender/blender

# ── Storage ───────────────────────────────────────────────────────────────────
# Directory where job workspaces are stored (created automatically)
WORKSPACE_DIR=./workspace

# How many hours to keep a session before automatic cleanup (default 48h)
SESSION_TTL_HOURS=48

# Maximum number of jobs allowed in the queue at once
MAX_QUEUE_SIZE=10
